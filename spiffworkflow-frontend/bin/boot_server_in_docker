#!/usr/bin/env bash

function error_handler() {
  echo >&2 "Exited with BAD EXIT CODE '${2}' in ${0} script at line: ${1}."
  exit "$2"
}
trap 'error_handler ${LINENO} $?' ERR
set -o errtrace -o errexit -o nounset -o pipefail

# Known plain env keys (no SPIFFWORKFLOW_FRONTEND_RUNTIME_CONFIG_ prefix) to inject when set.
# ECS task definitions often set BACKEND_BASE_URL directly; other config.tsx keys can be added here.
PLAIN_CONFIG_KEYS="BACKEND_BASE_URL"

# Build combined list of KEY=value (prefixed vars first, then plain keys only if not already present).
config_pairs=""
while IFS= read -r line; do
  [[ -z "$line" ]] && continue
  raw_key="${line%%=*}"
  key="${raw_key#SPIFFWORKFLOW_FRONTEND_RUNTIME_CONFIG_}"
  [[ -z "$key" ]] && continue
  value="${line#*=}"
  value="$(printf '%s' "$value" | sed -E "s/(^['\"]|['\"]$)//g")"
  if [[ -n "$value" ]]; then
    config_pairs="${config_pairs}${key}=${value}"$'\n'
  fi
done <<< "$(env | grep -E '^SPIFFWORKFLOW_FRONTEND_RUNTIME_CONFIG_' || true)"

for key in $PLAIN_CONFIG_KEYS; do
  if echo "$config_pairs" | grep -q "^${key}="; then
    continue
  fi
  value="${!key:-}"
  if [[ -n "$value" ]]; then
    config_pairs="${config_pairs}${key}=${value}"$'\n'
  fi
done

# If we have any configs, inject them into index.html (single-pass sed).
if [[ -n "${config_pairs}" ]]; then
  index_html_file="/usr/share/nginx/html/index.html"
  if [[ ! -f "$index_html_file" ]]; then
    echo >&2 "ERROR: Could not find '${index_html_file}'. Cannot inject runtime config without it."
    exit 1
  fi

  if ! command -v sed >/dev/null; then
    echo >&2 "ERROR: sed command not found. Cannot inject runtime config without it."
    exit 1
  fi

  # Escape value for sed replacement and shell: \ -> \\, & -> \&, / -> \/, ' -> '\'', " -> \"
  escape_value() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/&/\\&/g; s|/|\\/|g; s/'\''/'\''\\'\'''\''/g; s/"/\\"/g'
  }

  inject_string=""
  while IFS= read -r pair; do
    [[ -z "$pair" ]] && continue
    key="${pair%%=*}"
    value="${pair#*=}"
    if [[ -z "$key" ]]; then
      echo >&2 "ERROR: Could not parse config pair: '${pair}'."
      exit 1
    fi
    if [[ -z "$value" ]]; then
      continue
    fi
    escaped_val="$(escape_value "$value")"
    inject_string="${inject_string};window.spiffworkflowFrontendJsenv.${key} = '${escaped_val}'"
  done <<< "$config_pairs"

  sed -i "s/\(window.spiffworkflowFrontendJsenv *= *{}\)/\1${inject_string}/" "$index_html_file"

  first_key="$(echo "$config_pairs" | head -1 | cut -d= -f1)"
  if [[ -n "$first_key" ]] && ! grep -q "spiffworkflowFrontendJsenv.${first_key} =" "$index_html_file"; then
    echo >&2 "ERROR: Could not find injected config '${first_key}' in '${index_html_file}'. HTML structure may have changed."
    echo >&2 "index.html: $(cat "$index_html_file")"
    exit 1
  fi
fi

port_to_use="${PORT0:-80}"
if [[ -n "${SPIFFWORKFLOW_FRONTEND_INTERNAL_PORT:-}" ]]; then
  port_to_use="$SPIFFWORKFLOW_FRONTEND_INTERNAL_PORT"
fi
sed "s/{{SPIFFWORKFLOW_FRONTEND_INTERNAL_PORT}}/${port_to_use}/g" /var/tmp/nginx.conf.template >/etc/nginx/conf.d/default.conf

exec nginx -g "daemon off;"
